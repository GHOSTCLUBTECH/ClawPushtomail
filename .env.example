# ─── ClawMail Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ── Email (IMAP + SMTP) ────────────────────────────────────────────────────────
IMAP_HOST=mail.yourdomain.com
SMTP_HOST=mail.yourdomain.com
IMAP_PORT=993
SMTP_PORT=465
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your_email_password
EMAIL_NAME=Your Name

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Behavior ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=60               # Seconds between inbox checks
ARCHIVE_FOLDER=INBOX.FORWARDED # IMAP folder to archive processed emails
ATTACHMENT_DIR=~/ClawMail       # Local directory to save attachments

# ── Signature ──────────────────────────────────────────────────────────────────
# Your email signature (plain text, appended to all outgoing replies)
# Use \n for line breaks in .env, or set EMAIL_SIGNATURE_FILE to a .txt path
EMAIL_SIGNATURE_FILE=signature.txt
